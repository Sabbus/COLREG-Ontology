    hasTarget(?scenario, ?target),
    hasLightInSight(?ownship, ?lights),
    equal(?lights, "all_round_red_light-all_round_red_light-all_round_white_light-masthead_light-red_sidelight-upper_masthead") -> hasPortsideInSight(?ownship, ?target), VesselRestrictedInHerAbilityToManoeuvre(?target)

