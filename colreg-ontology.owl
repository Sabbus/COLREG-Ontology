<?xml version="1.0"?>
<rdf:RDF xmlns="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#"
     xml:base="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1"
     xmlns:ns1="http://unige.it/nicola-sabatino/2024/7/8/colreg-vessel-categories-ontology/0.0.1#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:colreg-ontology="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#">
    <owl:Ontology rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasBehavior -->

    <owl:ObjectProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasBehavior">
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior"/>
    </owl:ObjectProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasEquipment -->

    <owl:ObjectProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasEquipment">
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
        <owl:propertyDisjointWith rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasStatus"/>
    </owl:ObjectProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasOwnship -->

    <owl:ObjectProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasOwnship">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
        <rdfs:range rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
    </owl:ObjectProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasStatus -->

    <owl:ObjectProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
    </owl:ObjectProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasTargetShip -->

    <owl:ObjectProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasTargetShip">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
        <rdfs:range rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasHeading -->

    <owl:DatatypeProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasHeading">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasSpeed -->

    <owl:DatatypeProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasSpeed">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasXPosition -->

    <owl:DatatypeProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasXPosition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasYPosition -->

    <owl:DatatypeProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasYPosition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior">
        <owl:disjointWith>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                </owl:unionOf>
            </owl:Class>
        </owl:disjointWith>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Crossing -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Crossing">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#DifferentVesselEncounter -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#DifferentVesselEncounter">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#DraughtConstrained -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#DraughtConstrained">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Engine -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Engine">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
        <owl:disjointWith rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManeouvrabilityRestrictingFishingEquipment"/>
        <owl:disjointWith rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Sail"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment">
        <owl:disjointWith>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                </owl:unionOf>
            </owl:Class>
        </owl:disjointWith>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#GiveWay -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#GiveWay">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#turn_right"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#HeadOn -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#HeadOn">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasOwnship"/>
                        <owl:allValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasBehavior"/>
                                <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#GiveWay"/>
                            </owl:Restriction>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasTargetShip"/>
                        <owl:allValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasBehavior"/>
                                <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#GiveWay"/>
                            </owl:Restriction>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManeouvrabilityRestrictingFishingEquipment -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManeouvrabilityRestrictingFishingEquipment">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManoeuvrabilityRestricted -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManoeuvrabilityRestricted">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#NotUnderCommand -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#NotUnderCommand">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Overtaking -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Overtaking">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#PowerDrivenVessel -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#PowerDrivenVessel">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasEquipment"/>
                                <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#ManeouvrabilityRestrictingFishingEquipment"/>
                            </owl:Restriction>
                        </owl:complementOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasEquipment"/>
                        <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Engine"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasStatus"/>
                        <owl:allValuesFrom>
                            <owl:Class>
                                <owl:complementOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
                            </owl:Class>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Sail -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Sail">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#SailingVessel -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#SailingVessel">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasEquipment"/>
                        <owl:allValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Sail"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasStatus"/>
                        <owl:allValuesFrom>
                            <owl:Class>
                                <owl:complementOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
                            </owl:Class>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#SailingVesselEncounter -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#SailingVesselEncounter">
        <rdfs:subClassOf rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario"/>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Scenario">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasOwnship"/>
                        <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasTargetShip"/>
                        <owl:someValuesFrom rdf:resource="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Behavior"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Equipment"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Status"/>
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#Vessel"/>
                </owl:unionOf>
            </owl:Class>
        </owl:disjointWith>
    </owl:Class>
    


    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#StandOn -->

    <owl:Class rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#StandOn">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#keep_course"/>
                </owl:oneOf>
