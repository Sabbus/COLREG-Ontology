Rule:
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2),
    DifferentFrom(?vessel1, ?vessel2),
    PowerDrivenVessel(?vessel1), SailingVessel(?vessel2) -> DifferentVesselEncounter(?scenario), hasBehavior(?vessel1, "alter_course"), hasBehavior(?vessel2, "keep_course")

