#        hasTarget nave_2,
#        hasWindDirDeg 270.0

################################################################################
# RULES ########################################################################
################################################################################

# UTILS ########################################################################
Rule: 
    hasHeadingDeg(?vessel, ?heading), multiply(?headingRad, ?heading, 0.017453) -> hasHeadingRad(?vessel, ?headingRad)

Rule: 
    hasWindDirDeg(?vessel, ?dir), multiply(?dirRad, ?dir, 0.017453) -> hasWindDirRad(?vessel, ?dirRad)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingDeg(?ownship, ?heading),
    hasTarget(?scenario, ?target), hasAbsoluteBearingWithRespectToOwnShip(?target, ?absoluteBearing),
    subtract(?temp1, ?absoluteBearing, ?heading),
    mod(?temp2, ?temp1, 360), add(?temp3, ?temp1, 360), mod(?relativeBearing, ?temp3, 360), lessThanOrEqual(?relativeBearing, 180) -> hasRelativeBearingWithRespectToOwnShip(?target, ?relativeBearing)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingDeg(?ownship, ?heading),
    hasTarget(?scenario, ?target), hasAbsoluteBearingWithRespectToOwnShip(?target, ?absoluteBearing),
    subtract(?temp1, ?absoluteBearing, ?heading),
    mod(?temp2, ?temp1, 360), add(?temp3, ?temp1, 360), mod(?temp4, ?temp3, 360), greaterThan(?temp4, 180),
    subtract(?relativeBearing, ?temp4, 360) -> hasRelativeBearingWithRespectToOwnShip(?target, ?relativeBearing)

Rule:
    hasVessel(?scenario, ?vessel1), hasSpeed(?vessel1, ?vessel1Speed),
    hasVessel(?scenario, ?vessel2), hasSpeed(?vessel2, ?vessel2Speed),
    DifferentFrom(?vessel1, ?vessel2),
    greaterThan(?vessel1Speed, ?vessel2Speed) -> fasterThan(?vessel1, ?vessel2), slowerThan(?vessel2, ?vessel1)

# RELATIVE POSITIONING #########################################################
# RELATIVE POSITIONING: ?deltaXPrime = 0
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    equal(?deltaXPrime, 0),
    greaterThan(?deltaYPrime, 0) -> hasOnStarboard(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    equal(?deltaXPrime, 0),
    lessThan(?deltaYPrime, 0) -> hasOnPortside(?ownship, ?target)

# RELATIVE POSITIONING: ?deltaXPrime != 0 AND ?deltaYPrime = 0
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), equal(?deltaYPrime, 0),
    greaterThan(?deltaXPrime, 0) -> hasAhead(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), equal(?deltaYPrime, 0),
    lessThan(?deltaXPrime, 0) -> hasBehind(?ownship, ?target)

# RELATIVE POSITIONING: ?deltaXPrime != 0 AND ?deltaYPrime != 0 AND ?deltaXPrime > 0
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), greaterThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?lower, -0.043633), tan(?upper, 0.043633),
    greaterThanOrEqual(?tan, ?lower), lessThanOrEqual(?tan, ?upper) -> hasAhead(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), greaterThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?lower, 0.043633),
    greaterThan(?tan, ?lower) -> hasOnStarboard(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), greaterThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?upper, -0.043633),
    lessThan(?tan, ?upper) -> hasOnPortside(?ownship, ?target)

# RELATIVE POSITIONING: ?deltaXPrime != 0 AND ?deltaYPrime != 0 AND ?deltaXPrime < 0
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), lessThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?upper, 1.963495),
    lessThan(?tan, ?upper) -> hasOnStarboard(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), lessThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?lower, -1.963495),
    greaterThan(?tan, ?lower) -> hasOnPortside(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?target, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    multiply(?deltaXPrime1, ?deltaX, ?cos), multiply(?deltaXPrime2, ?deltaY, ?sin), add(?deltaXPrime, ?deltaXPrime1, ?deltaXPrime2),
    multiply(?minusDeltaX, ?deltaX, -1), multiply(?deltaYPrime1, ?minusDeltaX, ?sin), multiply(?deltaYPrime2, ?deltaY, ?cos), add(?deltaYPrime, ?deltaYPrime1, ?deltaYPrime2),
    notEqual(?deltaXPrime, 0), notEqual(?deltaYPrime, 0), lessThan(?deltaXPrime, 0),
    divide(?tan, ?deltaYPrime, ?deltaXPrime), tan(?lower, 1.963495),
    greaterThanOrEqual(?tan, ?lower) -> hasBehind(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownship, ?ownshipY),
