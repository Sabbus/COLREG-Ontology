################################################################################
# RULES ########################################################################
################################################################################

# UTILS ########################################################################
Rule: 
    hasHeadingDeg(?vessel, ?heading), multiply(?headingRad, ?heading, 0.017) -> hasHeadingRad(?vessel, ?headingRad)

Rule: 
    hasWindDirDeg(?vessel, ?dir), multiply(?dirRad, ?dir, 0.017) -> hasWindDirRad(?vessel, ?dirRad)

Rule: 
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), 
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), 
    subtract(?difference, ?ownshipHeading, ?targetHeading), cos(?cos, ?difference) -> hasDotProductOfCourses(?scenario, ?cos)

Rule: 
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), 
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), 
    subtract(?difference, ?ownshipHeading, ?targetHeading), sin(?sin, ?difference) -> hasCrossProductOfCourses(?scenario, ?sin)

# RELATIVE POSITIONING #########################################################
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?ownshipX, ?targetX), subtract(?deltaY, ?ownshipY, ?targetY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempUpper, 3.05326), multiply(?upper, ?tempUpper, ?modulusSquared), multiply(?negativeModulus, ?modulusSquared, -1),
    lessThan(?dotProduct, ?upper), lessThanOrEqual(?negativeModulus, ?dotProduct) -> hasAhead(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?ownshipX, ?targetX), subtract(?deltaY, ?ownshipY, ?targetY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct) -> hasBehind(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?ownshipX, ?targetX), subtract(?deltaY, ?ownshipY, ?targetY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 3.05326), multiply(?lower, ?tempLower, ?modulusSquared), cos(?tempUpper, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct),
    hasCrossProductOfCourses(?scenario, ?crossProduct), lessThanOrEqual(?crossProduct, 0) -> hasOnStarboard(?ownship, ?target)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?ownshipX, ?targetX), subtract(?deltaY, ?ownshipY, ?targetY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?ownshipHeading), sin(?sin, ?ownshipHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 3.05326), multiply(?lower, ?tempLower, ?modulusSquared), cos(?tempUpper, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct),
    hasCrossProductOfCourses(?scenario, ?crossProduct), greaterThan(?crossProduct, 0) -> hasOnPortside(?ownship, ?target)

# WIND #########################################################################
Rule:
    hasVessel(?scenario, ?vessel), hasHeadingRad(?vessel, ?heading),
    hasWindDirRad(?scenario, ?windDir),
    subtract(?difference, ?heading, ?windDir), sin(?sin, ?difference), lessThanOrEqual(?sin, 0) -> hasWindOnSide(?vessel, "portside"^^xsd:string)

Rule:
    hasVessel(?scenario, ?vessel), hasHeadingRad(?vessel, ?heading),
    hasWindDirRad(?scenario, ?windDir),
    subtract(?difference, ?heading, ?windDir), sin(?sin, ?difference), greaterThan(?sin, 0) -> hasWindOnSide(?vessel, "starboard"^^xsd:string)

# SIGHTING #####################################################################
Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?targetHeading), sin(?sin, ?targetHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempUpper, 3.05326), multiply(?upper, ?tempUpper, ?modulusSquared), multiply(?negativeModulus, ?modulusSquared, -1),
    lessThan(?dotProduct, ?upper), lessThanOrEqual(?negativeModulus, ?dotProduct) -> hasInSight(?ownship, "bow"^^xsd:string)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?targetHeading), sin(?sin, ?targetHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct) -> hasInSight(?ownship, "stern"^^xsd:string)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?targetHeading), sin(?sin, ?targetHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 3.05326), multiply(?lower, ?tempLower, ?modulusSquared), cos(?tempUpper, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct),
    hasCrossProductOfCourses(?scenario, ?crossProduct), lessThanOrEqual(?crossProduct, 0) -> hasInSight(?ownship, "starboard"^^xsd:string)

Rule:
    hasOwnship(?scenario, ?ownship), hasHeadingRad(?ownship, ?ownshipHeading), hasXPosition(?ownship, ?ownshipX), hasYPosition(?ownsship, ?ownshipY),
    hasTarget(?scenario, ?target), hasHeadingRad(?target, ?targetHeading), hasXPosition(?target, ?targetX), hasYPosition(?ownsship, ?targetY),
    subtract(?deltaX, ?targetX, ?ownshipX), subtract(?deltaY, ?targetY, ?ownshipY), pow(?deltaXSquared, ?deltaX, 2), pow(?deltaYSquared, ?deltaY, 2), add(?modulusSquared, ?deltaXSquared, ?deltaYSquared),
    cos(?cos, ?targetHeading), sin(?sin, ?targetHeading),
    add(?temp1, ?deltaX, ?cos), add(?temp2, ?deltaY, ?sin), add(?dotProduct, ?temp1, ?temp2),
    cos(?tempLower, 3.05326), multiply(?lower, ?tempLower, ?modulusSquared), cos(?tempUpper, 1.178097), multiply(?lower, ?tempLower, ?modulusSquared),
    lessThan(?dotProduct, ?modulusSquared), lessThanOrEqual(?lower, ?dotProduct),
    hasCrossProductOfCourses(?scenario, ?crossProduct), greaterThan(?crossProduct, 0) -> hasInSight(?ownship, "portside"^^xsd:string)

# HEAD-ON ######################################################################
# cos(180) <= ?dotProduct < cos(175)
Rule: 
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), 
    hasAhead(?ownship, ?target), hasInSight(?ownship, "bow"^^xsd:string) -> HeadOn(?scenario)

Rule:
    HeadOn(?scenario),
    hasOwnship(?scenario, ?ownship) -> hasBehavior(?ownship, "alter_course"^^xsd:string)

Rule:
    HeadOn(?scenario),
    hasTarget(?scenario, ?target) -> hasBehavior(?target, "alter_course"^^xsd:string)

# CROSSING #####################################################################
# cos(175) <= ?dotProduct < cos(67.5)
Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target),
    hasOnPortside(?ownship, ?target), hasInSight(?ownship, "starboard"^^xsd:string) -> Crossing(?scenario)

Rule:
    Crossing(?scenario),
    hasOwnship(?scenario, ?ownship), hasTarget(?scenario, ?target),
    hasOnPortside(?ownship, ?target), hasInSight(?ownship, "starboard"^^xsd:string) -> hasBehavior(?ownship, "keep_course"^^xsd:string)

Rule:
    Crossing(?scenario),
    hasOwnship(?scenario, ?ownship), hasTarget(?scenario, ?target),
    hasOnPortside(?ownship, ?target), hasInSight(?ownship, "starboard"^^xsd:string) -> hasBehavior(?target, "alter_course"^^xsd:string)

Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target),
    hasOnStarboard(?ownship, ?target), hasInSight(?ownship, "portside"^^xsd:string) -> Crossing(?scenario)

Rule:
    Crossing(?scenario),
    hasOwnship(?scenario, ?ownship), hasTarget(?scenario, ?target),
    hasOnStarboard(?ownship, ?target), hasInSight(?ownship, "portside"^^xsd:string) -> hasBehavior(?ownship, "alter_course"^^xsd:string)

Rule:
    Crossing(?scenario),
    hasOwnship(?scenario, ?ownship), hasTarget(?scenario, ?target),
    hasOnStarboard(?ownship, ?target), hasInSight(?ownship, "portside"^^xsd:string) -> hasBehavior(?target, "keep_course"^^xsd:string)

# OVERTAKING ###################################################################
# cos(67.5) <= ?dotProduct <= cos(0)
Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), hasSpeed(?target, ?targetSpeed),
    hasBehind(?ownship, ?target), hasInSight(?ownship, "bow"^^xsd:string),
    lessThan(?ownshipSpeed, ?targetSpeed) -> Overtaking(?scenario)

Rule:
    Overtaking(?scenario),
    hasOwnship(?scenario, ?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), hasSpeed(?target, ?targetSpeed),
    hasBehind(?ownship, ?target), hasInSight(?ownship, "bow"^^xsd:string),
    lessThan(?ownshipSpeed, ?targetSpeed) -> hasBehavior(?ownship, "keep_course"^^xsd:string)

Rule:
    Overtaking(?scenario),
    hasOwnship(?scenario, ?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), hasSpeed(?target, ?targetSpeed),
    hasBehind(?ownship, ?target), hasInSight(?ownship, "bow"^^xsd:string),
    lessThan(?ownshipSpeed, ?targetSpeed) -> hasBehavior(?target, "alter_course"^^xsd:string)

Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), hasSpeed(?target, ?targetSpeed),
    hasAhead(?ownship, ?target), hasInSight(?ownship, "stern"^^xsd:string),
    greaterThan(?ownshipSpeed, ?targetSpeed) -> Overtaking(?scenario)

Rule:
    Overtaking(?scenario),
    hasOwnship(?scenario, ?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), hasSpeed(?target, ?targetSpeed),
    hasAhead(?ownship, ?target), hasInSight(?ownship, "stern"^^xsd:string),
    greaterThan(?ownshipSpeed, ?targetSpeed) -> hasBehavior(?target, "keep_course"^^xsd:string)

Rule:
    Overtaking(?scenario),
    hasOwnship(?scenario, ?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), hasSpeed(?target, ?targetSpeed),
    hasAhead(?ownship, ?target), hasInSight(?ownship, "stern"^^xsd:string),
    greaterThan(?ownshipSpeed, ?targetSpeed) -> hasBehavior(?ownship, "alter_course"^^xsd:string)

# SAILING VESSEL ENCOUNTER #####################################################
Rule:
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    SailingVessel(?vessel1), SailingVessel(?vessel2) -> SailingVesselEncounter(?scenario)

# SAILING VESSEL ENCOUNTER: DIFFERENT SIDE #####################################
Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "starboard"^^xsd:string), hasWindOnSide(?vessel2, "portside"^^xsd:string) -> hasBehavior(?vessel1, "keep_course"^^xsd:string)

Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "starboard"^^xsd:string), hasWindOnSide(?vessel2, "portside"^^xsd:string) -> hasBehavior(?vessel2, "alter_course"^^xsd:string)

# SAILING VESSEL ENCOUNTER: SAME SIDE ##########################################
Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "starboard"^^xsd:string), hasWindOnSide(?vessel2, "starboard"^^xsd:string),
    hasXPosition(?vessel1, ?vessel1X), hasYPosition(?vessel1, ?vessel1Y), hasXPosition(?vessel2, ?vessel2X), hasYPosition(?vessel2, ?vessel2Y),
    subtract(?deltaX, ?vessel1X, ?vessel2X), subtract(?deltaY, ?vessel1Y, ?vessel2Y),
    hasWindDirRad(?scenario, ?windDir),
    cos(?windX, ?windDir), sin(?windY, ?windDir),
    multiply(?temp1, ?deltaX, ?windX), multiply(?temp2, ?deltaY, ?windY), add(?dotProduct, ?temp1, ?temp2),
    lessThan(?dotProduct, 0) -> hasBehavior(?vessel1, "alter_course"^^xsd:string)

Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "starboard"^^xsd:string), hasWindOnSide(?vessel2, "starboard"^^xsd:string),
    hasXPosition(?vessel1, ?vessel1X), hasYPosition(?vessel1, ?vessel1Y), hasXPosition(?vessel2, ?vessel2X), hasYPosition(?vessel2, ?vessel2Y),
    subtract(?deltaX, ?vessel1X, ?vessel2X), subtract(?deltaY, ?vessel1Y, ?vessel2Y),
    hasWindDirRad(?scenario, ?windDir),
    cos(?windX, ?windDir), sin(?windY, ?windDir),
    multiply(?temp1, ?deltaX, ?windX), multiply(?temp2, ?deltaY, ?windY), add(?dotProduct, ?temp1, ?temp2),
    lessThan(?dotProduct, 0) -> hasBehavior(?vessel2, "keep_course"^^xsd:string)

Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "portside"^^xsd:string), hasWindOnSide(?vessel2, "portside"^^xsd:string),
    hasXPosition(?vessel1, ?vessel1X), hasYPosition(?vessel1, ?vessel1Y), hasXPosition(?vessel2, ?vessel2X), hasYPosition(?vessel2, ?vessel2Y),
    subtract(?deltaX, ?vessel1X, ?vessel2X), subtract(?deltaY, ?vessel1Y, ?vessel2Y),
    hasWindDirRad(?scenario, ?windDir),
    cos(?windX, ?windDir), sin(?windY, ?windDir),
    multiply(?temp1, ?deltaX, ?windX), multiply(?temp2, ?deltaY, ?windY), add(?dotProduct, ?temp1, ?temp2),
    lessThan(?dotProduct, 0) -> hasBehavior(?vessel1, "alter_course"^^xsd:string)

Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "portside"^^xsd:string), hasWindOnSide(?vessel2, "portside"^^xsd:string),
    hasXPosition(?vessel1, ?vessel1X), hasYPosition(?vessel1, ?vessel1Y), hasXPosition(?vessel2, ?vessel2X), hasYPosition(?vessel2, ?vessel2Y),
    subtract(?deltaX, ?vessel1X, ?vessel2X), subtract(?deltaY, ?vessel1Y, ?vessel2Y),
    hasWindDirRad(?scenario, ?windDir),
    cos(?windX, ?windDir), sin(?windY, ?windDir),
    multiply(?temp1, ?deltaX, ?windX), multiply(?temp2, ?deltaY, ?windY), add(?dotProduct, ?temp1, ?temp2),
    lessThan(?dotProduct, 0) -> hasBehavior(?vessel2, "keep_course"^^xsd:string)

# DIFFERENT VESSEL ENCOUNTER: POWER vs SAILING #################################
Rule:
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2),
    DifferentFrom(?vessel1, ?vessel2),
