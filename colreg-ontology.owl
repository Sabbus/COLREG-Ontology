    <!-- http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasHeadingRad -->

    <owl:DatatypeProperty rdf:about="http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1#hasHeadingRad">
