@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Object Properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#hasEquipment
<http://www.co-ode.org/ontologies/ont.owl#hasEquipment> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Vessel> ;
                                                        rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Equipment> .


###  http://www.co-ode.org/ontologies/ont.owl#hasOwnship
<http://www.co-ode.org/ontologies/ont.owl#hasOwnship> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <http://www.co-ode.org/ontologies/ont.owl#hasVessel> ;
                                                      rdf:type owl:FunctionalProperty ;
                                                      rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Scenario> ;
                                                      rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#hasStatus
<http://www.co-ode.org/ontologies/ont.owl#hasStatus> rdf:type owl:ObjectProperty ;
                                                     rdfs:subPropertyOf owl:topObjectProperty ;
                                                     rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Vessel> ;
                                                     rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Status> .


###  http://www.co-ode.org/ontologies/ont.owl#hasTargetShip
<http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <http://www.co-ode.org/ontologies/ont.owl#hasVessel> ;
                                                         rdf:type owl:FunctionalProperty ;
                                                         rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Scenario> ;
                                                         rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#hasVessel
<http://www.co-ode.org/ontologies/ont.owl#hasVessel> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Scenario> ;
                                                     rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


#################################################################
#    Classes
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#Behavior
<http://www.co-ode.org/ontologies/ont.owl#Behavior> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#Crossing
<http://www.co-ode.org/ontologies/ont.owl#Crossing> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Scenario> ,
                                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasOwnship> ;
                                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> ;
                                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] .


###  http://www.co-ode.org/ontologies/ont.owl#DifferentVesselEncounter
<http://www.co-ode.org/ontologies/ont.owl#DifferentVesselEncounter> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Scenario> .


###  http://www.co-ode.org/ontologies/ont.owl#DraughtConstrained
<http://www.co-ode.org/ontologies/ont.owl#DraughtConstrained> rdf:type owl:Class ;
                                                              rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Status> .


###  http://www.co-ode.org/ontologies/ont.owl#Engine
<http://www.co-ode.org/ontologies/ont.owl#Engine> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Equipment> .


###  http://www.co-ode.org/ontologies/ont.owl#Equipment
<http://www.co-ode.org/ontologies/ont.owl#Equipment> rdf:type owl:Class ;
                                                     owl:equivalentClass [ rdf:type owl:Class ;
                                                                           owl:unionOf ( <http://www.co-ode.org/ontologies/ont.owl#Engine>
                                                                                         <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment>
                                                                                         <http://www.co-ode.org/ontologies/ont.owl#Sail>
                                                                                       )
                                                                         ] .


###  http://www.co-ode.org/ontologies/ont.owl#GiveWay
<http://www.co-ode.org/ontologies/ont.owl#GiveWay> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Behavior> ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#Role> ;
                                                   owl:disjointWith <http://www.co-ode.org/ontologies/ont.owl#StandOn> .


###  http://www.co-ode.org/ontologies/ont.owl#HeadOn
<http://www.co-ode.org/ontologies/ont.owl#HeadOn> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Scenario> ,
                                                                  [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasOwnship> ;
                                                                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                           owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                         ]
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> ;
                                                                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                           owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] .


###  http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestricted
<http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestricted> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Status> .


###  http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment
<http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Equipment> .


###  http://www.co-ode.org/ontologies/ont.owl#NotUnderCommand
<http://www.co-ode.org/ontologies/ont.owl#NotUnderCommand> rdf:type owl:Class ;
                                                           rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Status> .


###  http://www.co-ode.org/ontologies/ont.owl#Overtaking
<http://www.co-ode.org/ontologies/ont.owl#Overtaking> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Scenario> ,
                                                                      [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasOwnship> ;
                                                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                               owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                             ]
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> ;
                                                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                               owl:onClass <http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel>
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] .


###  http://www.co-ode.org/ontologies/ont.owl#Portside
<http://www.co-ode.org/ontologies/ont.owl#Portside> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#WindDirection> ;
                                                    owl:disjointWith <http://www.co-ode.org/ontologies/ont.owl#Starboard> .


###  http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel
<http://www.co-ode.org/ontologies/ont.owl#PowerDrivenVessel> rdf:type owl:Class ;
                                                             owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                        [ rdf:type owl:Class ;
                                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                                             owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                                             owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment>
                                                                                                                           ]
                                                                                                        ]
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                          owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Engine>
                                                                                                        ]
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                          owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                                              owl:complementOf <http://www.co-ode.org/ontologies/ont.owl#Status>
                                                                                                                            ]
                                                                                                        ]
                                                                                                      ) ;
                                                                                   rdf:type owl:Class
                                                                                 ] ;
                                                             rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#Role
<http://www.co-ode.org/ontologies/ont.owl#Role> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#Sail
<http://www.co-ode.org/ontologies/ont.owl#Sail> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Equipment> .


###  http://www.co-ode.org/ontologies/ont.owl#SailingVessel
<http://www.co-ode.org/ontologies/ont.owl#SailingVessel> rdf:type owl:Class ;
                                                         owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                    [ rdf:type owl:Class ;
                                                                                                      owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                                         owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment>
                                                                                                                       ]
                                                                                                    ]
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Sail>
                                                                                                    ]
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                      owl:allValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Sail>
                                                                                                    ]
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                      owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                                          owl:complementOf <http://www.co-ode.org/ontologies/ont.owl#Status>
                                                                                                                        ]
                                                                                                    ]
                                                                                                  ) ;
                                                                               rdf:type owl:Class
                                                                             ] ;
                                                         rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#SailingVesselEncounter
<http://www.co-ode.org/ontologies/ont.owl#SailingVesselEncounter> rdf:type owl:Class ;
                                                                  owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasOwnship> ;
                                                                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                               owl:onClass <http://www.co-ode.org/ontologies/ont.owl#SailingVessel>
                                                                                                             ]
                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> ;
                                                                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                               owl:onClass <http://www.co-ode.org/ontologies/ont.owl#SailingVessel>
                                                                                                             ]
                                                                                                           ) ;
                                                                                        rdf:type owl:Class
                                                                                      ] ;
                                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Scenario> .


###  http://www.co-ode.org/ontologies/ont.owl#Scenario
<http://www.co-ode.org/ontologies/ont.owl#Scenario> rdf:type owl:Class ;
                                                    owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasOwnship> ;
                                                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                 owl:onClass <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                               ]
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasTargetShip> ;
                                                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                 owl:onClass <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                               ]
                                                                                             ) ;
                                                                          rdf:type owl:Class
                                                                        ] .


###  http://www.co-ode.org/ontologies/ont.owl#StandOn
<http://www.co-ode.org/ontologies/ont.owl#StandOn> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Behavior> ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#Role> .


###  http://www.co-ode.org/ontologies/ont.owl#Starboard
<http://www.co-ode.org/ontologies/ont.owl#Starboard> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#WindDirection> .


###  http://www.co-ode.org/ontologies/ont.owl#Status
<http://www.co-ode.org/ontologies/ont.owl#Status> rdf:type owl:Class ;
                                                  owl:equivalentClass [ rdf:type owl:Class ;
                                                                        owl:unionOf ( <http://www.co-ode.org/ontologies/ont.owl#DraughtConstrained>
                                                                                      <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestricted>
                                                                                      <http://www.co-ode.org/ontologies/ont.owl#NotUnderCommand>
                                                                                    )
                                                                      ] .


###  http://www.co-ode.org/ontologies/ont.owl#Vessel
<http://www.co-ode.org/ontologies/ont.owl#Vessel> rdf:type owl:Class ;
                                                  rdfs:subClassOf [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                           owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Equipment>
                                                                                         ]
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                           owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                           owl:onClass <http://www.co-ode.org/ontologies/ont.owl#Status>
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] .


###  http://www.co-ode.org/ontologies/ont.owl#VesselConstrainedByHerDraught
<http://www.co-ode.org/ontologies/ont.owl#VesselConstrainedByHerDraught> rdf:type owl:Class ;
                                                                         owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#DraughtConstrained>
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                                      owl:allValuesFrom <http://www.co-ode.org/ontologies/ont.owl#DraughtConstrained>
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ] ;
                                                                         rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#VesselEngagedInFishing
<http://www.co-ode.org/ontologies/ont.owl#VesselEngagedInFishing> rdf:type owl:Class ;
                                                                  owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                                               owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment>
                                                                                                             ]
                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                                                   owl:complementOf <http://www.co-ode.org/ontologies/ont.owl#Status>
                                                                                                                                 ]
                                                                                                             ]
                                                                                                           ) ;
                                                                                        rdf:type owl:Class
                                                                                      ] ;
                                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#VesselNotUnderCommand
<http://www.co-ode.org/ontologies/ont.owl#VesselNotUnderCommand> rdf:type owl:Class ;
                                                                 owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                              owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                              owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#NotUnderCommand>
                                                                                                            ]
                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                              owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                              owl:allValuesFrom <http://www.co-ode.org/ontologies/ont.owl#NotUnderCommand>
                                                                                                            ]
                                                                                                          ) ;
                                                                                       rdf:type owl:Class
                                                                                     ] ;
                                                                 rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#VesselRestrictedInHerAbilityToManoeuvre
<http://www.co-ode.org/ontologies/ont.owl#VesselRestrictedInHerAbilityToManoeuvre> rdf:type owl:Class ;
                                                                                   owl:equivalentClass [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                                owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                                                owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestricted>
                                                                                                                              ]
                                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                                owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                                                                owl:allValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestricted>
                                                                                                                              ]
                                                                                                                            ) ;
                                                                                                         rdf:type owl:Class
                                                                                                       ] ;
                                                                                   rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Vessel> .


###  http://www.co-ode.org/ontologies/ont.owl#WindDirection
<http://www.co-ode.org/ontologies/ont.owl#WindDirection> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#pippo
<http://www.co-ode.org/ontologies/ont.owl#pippo> rdf:type owl:NamedIndividual ,
                                                          [ owl:intersectionOf ( <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Engine>
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#ManoeuvrabilityRestrictingFishingEquipment>
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasEquipment> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Sail>
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasStatus> ;
                                                                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                       owl:complementOf <http://www.co-ode.org/ontologies/ont.owl#Status>
                                                                                                     ]
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.co-ode.org/ontologies/ont.owl#Behavior>
                <http://www.co-ode.org/ontologies/ont.owl#Equipment>
                <http://www.co-ode.org/ontologies/ont.owl#Scenario>
                <http://www.co-ode.org/ontologies/ont.owl#Status>
                <http://www.co-ode.org/ontologies/ont.owl#Vessel>
                <http://www.co-ode.org/ontologies/ont.owl#WindDirection>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.co-ode.org/ontologies/ont.owl#Behavior>
                <http://www.co-ode.org/ontologies/ont.owl#Equipment>
                <http://www.co-ode.org/ontologies/ont.owl#Scenario>
                <http://www.co-ode.org/ontologies/ont.owl#Status>
                <http://www.co-ode.org/ontologies/ont.owl#WindDirection>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
