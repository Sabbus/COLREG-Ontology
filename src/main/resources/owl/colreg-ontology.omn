    equal(?lights, "all_round_red_light-all_round_red_light-all_round_white_light-green_sidelight-masthead_light-upper_masthead_light") -> hasStarboardInSight(?ownship, ?target), VesselRestrictedInHerAbilityToManoeuvre(?target)

