Prefix: owl: <http://www.w3.org/2000/07/owl#>
Prefix: rdf: <http://www.w3.org/2000/01/rdf-schema#>
Prefix: rdfs: <http://www.w3.org/2000/01/rdf-schema#>
Prefix: xml: <http://www.w3.org/XML/1998/namespace>
Prefix: xsd: <http://www.w3.org/2001/XMLSchema#>

Prefix: : <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#>

Ontology: <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology> <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology-v0.1.0>

################################################################################
# OBJECTPROPERTIES #############################################################
################################################################################
ObjectProperty: hasOwnship
    SubPropertyOf: hasVessel
    DisjointWith: hasTarget
    Domain: Scenario
    Range: OwnShip
    Characteristics: Functional
    
ObjectProperty: hasTarget
    SubPropertyOf: hasVessel
    DisjointWith: hasOwnship
    Domain: Scenario
    Range: TargetShip
    Characteristics: Functional
    
ObjectProperty: hasVessel
    Domain: Scenario
    Range: Vessel

ObjectProperty: hasAhead
    Domain: OwnShip
    Range: TargetShip
    
ObjectProperty: hasBehind
    Domain: OwnShip
    Range: TargetShip
    
ObjectProperty: hasOnStarboard
    Domain: OwnShip
    Range: TargetShip
    
ObjectProperty: hasOnPortside
    Domain: OwnShip
    Range: TargetShip

ObjectProperty: hasBowInSight
    Domain: OwnShip
    Range: TargetShip

ObjectProperty: hasSternInSight
    Domain: OwnShip
    Range: TargetShip

ObjectProperty: hasStarboardInSight
    Domain: OwnShip
    Range: TargetShip

ObjectProperty: hasPortsideInSight
    Domain: OwnShip
    Range: TargetShip

ObjectProperty: slowerThan
    Domain: Vessel
    Range: Vessel
    InverseOf: fasterThan

ObjectProperty: fasterThan
    Domain: Vessel
    Range: Vessel
    InverseOf: slowerThan

DisjointProperties: hasAhead, hasBehind, hasOnStarboard, hasOnPortside
DisjointProperties: hasBowInSight, hasSternInSight, hasStarboardInSight, hasPortsideInSight
DisjointProperties: slowerThan, fasterThan

################################################################################
# DATAPROPERTIES ###############################################################
################################################################################
DataProperty: print

DataProperty: hasBehavior
    Domain: Vessel
    Range: {"alter_course" , "keep_course"}
    Characteristics: Functional
    
DataProperty: hasHeadingDeg
    Domain: Vessel
    Range: xsd:decimal[>=0, <=360]
    Characteristics: Functional
    
DataProperty: hasHeadingRad
    Domain: Vessel
    Range: xsd:decimal
    Characteristics: Functional
    
DataProperty: hasSpeed
    Domain: Vessel
    Range: xsd:decimal[>=0]
    Characteristics: Functional
    
DataProperty: hasWindDirDeg
    Domain: Scenario
    Range: xsd:decimal
    Characteristics: Functional
    
DataProperty: hasWindDirRad
    Domain: Scenario
    Range: xsd:decimal[>=0, <=360]
    Characteristics: Functional
    
DataProperty: hasWindOnSide
    Domain: Vessel
    Range: {"portside" , "starboard"}
    Characteristics: Functional
    
DataProperty: hasXPosition
    Domain: Vessel
    Range: xsd:decimal
    Characteristics: Functional
    
DataProperty: hasYPosition
    Domain: Vessel
    Range: xsd:decimal
    Characteristics: Functional

DataProperty: hasAbsoluteBearingWithRespectToOwnShip
    Domain: TargetShip
    Range: xsd:decimal[>=0, <=360]
    Characteristics: Functional
    
DataProperty: hasRelativeBearingWithRespectToOwnShip
    Domain: TargetShip
    Range: xsd:decimal[>=-180, <=180]
    Characteristics: Functional

DataProperty: hasLightInSight
    Domain: OwnShip
    #Range: {"masthead_light", "upper_masthead_light", "green_sidelight", "red_sidelight", "sternlight"}
    Range: xsd:string
    Characteristics: Functional
    
################################################################################
# CLASSES ######################################################################
################################################################################

# SCENARIOS ####################################################################
Class: Scenario
    EquivalentTo: Crossing or DifferentVesselEncounter or HeadOn or Overtaking or SailingVesselEncounter
    
Class: HeadOn
    SubClassOf: Scenario

Class: Crossing
    SubClassOf: Scenario

Class: Overtaking
    SubClassOf: Scenario

Class: SailingVesselEncounter
    SubClassOf: Scenario

Class: DifferentVesselEncounter
    SubClassOf: Scenario

