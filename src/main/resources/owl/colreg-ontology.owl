@prefix : <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#> .

<http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology> rdf:type owl:Ontology ;
                                                            owl:versionIRI <http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology/0.0.1> .

#################################################################
#    Object Properties
#################################################################

###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#hasEquipment
:hasEquipment rdf:type owl:ObjectProperty ;
              rdfs:domain :Vessel ;
              rdfs:range :Equipment .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#hasOwnship
:hasOwnship rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasVessel ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Scenario ;
            rdfs:range :Vessel .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Vessel ;
           rdfs:range :Status .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#hasTargetShip
:hasTargetShip rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasVessel ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :Scenario ;
               rdfs:range :Vessel .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#hasVessel
:hasVessel rdf:type owl:ObjectProperty ;
           rdfs:domain :Scenario ;
           rdfs:range :Vessel .


#################################################################
#    Classes
#################################################################

###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#COLREGCategory
:COLREGCategory rdf:type owl:Class ;
                rdfs:subClassOf :Vessel .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Crossing
:Crossing rdf:type owl:Class ;
          rdfs:subClassOf :Scenario ,
                          [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasOwnship ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass :PowerDrivenVessel
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasTargetShip ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass :PowerDrivenVessel
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#DifferentVesselEncounter
:DifferentVesselEncounter rdf:type owl:Class ;
                          rdfs:subClassOf :Scenario .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#DraughtConstrained
:DraughtConstrained rdf:type owl:Class ;
                    rdfs:subClassOf :Status .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Engine
:Engine rdf:type owl:Class ;
        rdfs:subClassOf :Equipment .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Equipment
:Equipment rdf:type owl:Class ;
           owl:equivalentClass [ rdf:type owl:Class ;
                                 owl:unionOf ( :Engine
                                               :ManoeuvrabilityRestrictingFishingEquipment
                                               :Sail
                                             )
                               ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#GiveWay
:GiveWay rdf:type owl:Class ;
         owl:disjointWith :StandOn .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#HeadOn
:HeadOn rdf:type owl:Class ;
        rdfs:subClassOf :Scenario ,
                        [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasOwnship ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass :PowerDrivenVessel
                                               ]
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasTargetShip ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass :PowerDrivenVessel
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#ManoeuvrabilityRestricted
:ManoeuvrabilityRestricted rdf:type owl:Class ;
                           rdfs:subClassOf :Status .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#ManoeuvrabilityRestrictingFishingEquipment
:ManoeuvrabilityRestrictingFishingEquipment rdf:type owl:Class ;
                                            rdfs:subClassOf :Equipment .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#NotUnderCommand
:NotUnderCommand rdf:type owl:Class ;
                 rdfs:subClassOf :Status .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Overtaking
:Overtaking rdf:type owl:Class ;
            rdfs:subClassOf :Scenario ,
                            [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasOwnship ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass :PowerDrivenVessel
                                                   ]
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasTargetShip ;
                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                     owl:onClass :PowerDrivenVessel
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#PowerDrivenVessel
:PowerDrivenVessel rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :Vessel
                                                              [ rdf:type owl:Class ;
                                                                owl:complementOf [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty :hasEquipment ;
                                                                                   owl:someValuesFrom :ManoeuvrabilityRestrictingFishingEquipment
                                                                                 ]
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasEquipment ;
                                                                owl:someValuesFrom :Engine
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :hasStatus ;
                                                                owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:complementOf :Status
                                                                                  ]
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :Vessel .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Sail
:Sail rdf:type owl:Class ;
      rdfs:subClassOf :Equipment .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#SailingVessel
:SailingVessel rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Vessel
                                                          [ rdf:type owl:Class ;
                                                            owl:complementOf [ rdf:type owl:Restriction ;
                                                                               owl:onProperty :hasEquipment ;
                                                                               owl:someValuesFrom :ManoeuvrabilityRestrictingFishingEquipment
                                                                             ]
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasEquipment ;
                                                            owl:someValuesFrom :Sail
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasEquipment ;
                                                            owl:allValuesFrom :Sail
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasStatus ;
                                                            owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                owl:complementOf :Status
                                                                              ]
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :COLREGCategory .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#SailingVesselEncounter
:SailingVesselEncounter rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :Scenario
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasOwnship ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onClass :SailingVessel
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasTargetShip ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onClass :SailingVessel
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :Scenario .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Scenario
:Scenario rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasOwnship ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass :Vessel
                                                     ]
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :hasTargetShip ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass :Vessel
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#StandOn
:StandOn rdf:type owl:Class .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Status
:Status rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:unionOf ( :DraughtConstrained
                                            :ManoeuvrabilityRestricted
                                            :NotUnderCommand
                                          )
                            ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#Vessel
:Vessel rdf:type owl:Class ;
        rdfs:subClassOf [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasEquipment ;
                                                 owl:someValuesFrom :Equipment
                                               ]
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :hasStatus ;
                                                 owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass :Status
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#VesselConstrainedByHerDraught
:VesselConstrainedByHerDraught rdf:type owl:Class ;
                               owl:equivalentClass [ owl:intersectionOf ( :Vessel
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasStatus ;
                                                                            owl:someValuesFrom :DraughtConstrained
                                                                          ]
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasStatus ;
                                                                            owl:allValuesFrom :DraughtConstrained
                                                                          ]
                                                                        ) ;
                                                     rdf:type owl:Class
                                                   ] ;
                               rdfs:subClassOf :Vessel .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#VesselEngagedInFishing
:VesselEngagedInFishing rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :COLREGCategory
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasEquipment ;
                                                                     owl:someValuesFrom :ManoeuvrabilityRestrictingFishingEquipment
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasStatus ;
                                                                     owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                         owl:complementOf :Status
                                                                                       ]
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :COLREGCategory .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#VesselNotUnderCommand
:VesselNotUnderCommand rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :COLREGCategory
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasStatus ;
                                                                    owl:someValuesFrom :NotUnderCommand
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasStatus ;
                                                                    owl:allValuesFrom :NotUnderCommand
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :COLREGCategory .


###  http://unige.it/nicola-sabatino/2024/7/8/colreg-ontology#VesselRestrictedInHerAbilityToManoeuvre
:VesselRestrictedInHerAbilityToManoeuvre rdf:type owl:Class ;
                                         owl:equivalentClass [ owl:intersectionOf ( :COLREGCategory
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty :hasStatus ;
                                                                                      owl:someValuesFrom :ManoeuvrabilityRestricted
                                                                                    ]
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty :hasStatus ;
                                                                                      owl:allValuesFrom :ManoeuvrabilityRestricted
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                         rdfs:subClassOf :COLREGCategory .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Crossing
                :DifferentVesselEncounter
                :HeadOn
                :Overtaking
                :SailingVesselEncounter
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :DraughtConstrained
                :ManoeuvrabilityRestricted
                :NotUnderCommand
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Engine
                :ManoeuvrabilityRestrictingFishingEquipment
                :Sail
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :PowerDrivenVessel
                :SailingVessel
                :VesselConstrainedByHerDraught
                :VesselEngagedInFishing
                :VesselNotUnderCommand
                :VesselRestrictedInHerAbilityToManoeuvre
              )
] .


