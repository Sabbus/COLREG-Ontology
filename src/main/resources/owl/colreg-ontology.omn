# LIGHTS: AMBIGOUS CASES
# The following case is ambigous as an all-round white light could identify both the stern of a power driven vessel of length between 7 and 12 meters, or a power driven vessel less than 7 meters in length and sailing at speed not exceeding 7 Kn; the most conservative choice is represented here

Rule:
    hasOwnship(?scenario, ?ownship),
    hasTarget(?scenario, ?target),
    hasLightInSight(?ownship, "all_round_white_light") -> PowerDrivenVessel(?target)

# The following case is ambigous as a sternlight may identify both the stern of a power driven vessel or the stern of a sailing vessel
Rule:
    hasOwnship(?scenario, ?ownship),
    hasTarget(?scenario, ?target),
    hasLightInSight(?ownship, "sternlight") -> hasSternInSight(?ownship, ?target)

# HEAD-ON ######################################################################
Rule: 
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), 
    hasAhead(?ownship, ?target), hasBowInSight(?ownship, ?target) -> HeadOn(?scenario), hasBehavior(?ownship, "alter_course"), hasBehavior(?target, "alter_course")

# CROSSING #####################################################################
Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target),
    hasOnPortside(?ownship, ?target), hasStarboardInSight(?ownship, ?target) -> Crossing(?scenario), hasBehavior(?ownship, "keep_course"), hasBehavior(?target, "alter_course")

Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target),
    hasOnStarboard(?ownship, ?target), hasPortsideInSight(?ownship, ?target) -> Crossing(?scenario), hasBehavior(?ownship, "alter_course"), hasBehavior(?target, "keep_course")

# OVERTAKING ###################################################################
# cos(67.5) <= ?dotProduct <= cos(0)
Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), hasSpeed(?target, ?targetSpeed),
    hasBehind(?ownship, ?target), hasBowInSight(?ownship, ?target),
    lessThan(?ownshipSpeed, ?targetSpeed) -> Overtaking(?scenario), hasBehavior(?ownship, "keep_course"), hasBehavior(?target, "alter_course")

Rule:
    hasOwnship(?scenario, ?ownship), PowerDrivenVessel(?ownship), hasSpeed(?ownship, ?ownshipSpeed),
    hasTarget(?scenario, ?target), PowerDrivenVessel(?target), hasSpeed(?target, ?targetSpeed),
    hasAhead(?ownship, ?target), hasSternInSight(?ownship, ?target),
    greaterThan(?ownshipSpeed, ?targetSpeed) -> Overtaking(?scenario), hasBehavior(?target, "keep_course"), hasBehavior(?ownship, "alter_course")

# SAILING VESSEL ENCOUNTER #####################################################
Rule:
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    SailingVessel(?vessel1), SailingVessel(?vessel2) -> SailingVesselEncounter(?scenario)

# SAILING VESSEL ENCOUNTER: DIFFERENT SIDE #####################################
Rule:
    SailingVesselEncounter(?scenario),
    hasVessel(?scenario, ?vessel1), hasVessel(?scenario, ?vessel2), DifferentFrom(?vessel1, ?vessel2),
    hasWindOnSide(?vessel1, "starboard"), hasWindOnSide(?vessel2, "portside") -> hasBehavior(?vessel1, "keep_course"), hasBehavior(?vessel2, "alter_course")

# SAILING VESSEL ENCOUNTER: SAME SIDE ##########################################
Rule:
    SailingVesselEncounter(?scenario),
    hasOwnship(?scenario, ?ownship), hasWindOnSide(?ownship, "starboard"),
    hasTarget(?scenario, ?target), hasWindOnSide(?target, "starboard"),
    hasOnStarboard(?ownship, ?target) -> hasBehavior(?ownship, "keep_course"), hasBehavior(?target, "alter_course")

Rule:
    SailingVesselEncounter(?scenario),
    hasOwnship(?scenario, ?ownship), hasWindOnSide(?ownship, "starboard"),
    hasTarget(?scenario, ?target), hasWindOnSide(?target, "starboard"),
    hasOnPortside(?ownship, ?target) -> hasBehavior(?ownship, "alter_course"), hasBehavior(?target, "keep_course")

Rule:
    SailingVesselEncounter(?scenario),
    hasOwnship(?scenario, ?ownship), hasWindOnSide(?ownship, "portside"),
    hasTarget(?scenario, ?target), hasWindOnSide(?target, "portside"),
    hasOnStarboard(?ownship, ?target) -> hasBehavior(?ownship, "alter_course"), hasBehavior(?target, "keep_course")

Rule:
    SailingVesselEncounter(?scenario),
    hasOwnship(?scenario, ?ownship), hasWindOnSide(?ownship, "portside"),
    hasTarget(?scenario, ?target), hasWindOnSide(?target, "portside"),
    hasOnPortside(?ownship, ?target) -> hasBehavior(?ownship, "keep_course"), hasBehavior(?target, "alter_course")

